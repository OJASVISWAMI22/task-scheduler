# PostgreSQL
POSTGRES_USER=taskadmin
POSTGRES_PASSWORD=taskpassword
POSTGRES_DB=taskscheduler
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# C++ Service
CPP_SERVICE_URL=http://localhost:8080

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

#Database Pool 
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskscheduler
MIN_POOL_SIZE=2
MAX_POOL_SIZE=10
POOL_CMD_TIMEOUT=60